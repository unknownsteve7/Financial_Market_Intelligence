    "import requests\n",
    "url = 'https://api.github.com'\n",
    "\n",
    "\n",
    "\n",
    "params = {\n",
    "    \"search\": \"python\",\n",
    "    \"page\": 1\n",
    "}\n",
    "\n",
    "response = requests.get(url, params=params)\n",
    "print(response.text)"
